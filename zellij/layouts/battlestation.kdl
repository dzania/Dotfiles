layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="main" focus=true hide_floating_panes=true {
        pane split_direction="vertical" {
            pane size="30%"
            pane focus=true size="45%"
            pane size="25%"
        }
    }
}
