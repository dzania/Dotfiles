layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left   "#[bg=#151515,fg=#E1E1E1] {session} {mode}"
                format_center "{tabs}"
                format_right  "#[bg=#151515,fg=#E1E1E1] {datetime} "
                format_space  "#[bg=#151515] "

                border_enabled  "false"
                hide_frame_for_single_pane "false"

                datetime          "{format}"
                datetime_format   "%H:%M"
                datetime_timezone "Local"

                mode_normal       "#[bg=#151515,fg=#727272] NORMAL"
                mode_locked       "#[bg=#151515,fg=#E1E1E1] LOCKED"
                mode_resize       "#[bg=#151515,fg=#E1E1E1] RESIZE"
                mode_pane         "#[bg=#151515,fg=#E1E1E1] PANE"
                mode_tab          "#[bg=#151515,fg=#E1E1E1] TAB"
                mode_scroll       "#[bg=#151515,fg=#E1E1E1] SCROLL"
                mode_enter_search "#[bg=#151515,fg=#E1E1E1] SEARCH"
                mode_search       "#[bg=#151515,fg=#E1E1E1] SEARCH"
                mode_rename_tab   "#[bg=#151515,fg=#E1E1E1] RENAME"
                mode_rename_pane  "#[bg=#151515,fg=#E1E1E1] RENAME"
                mode_session      "#[bg=#151515,fg=#E1E1E1] SESSION"
                mode_move         "#[bg=#151515,fg=#E1E1E1] MOVE"
                mode_prompt       "#[bg=#151515,fg=#E1E1E1] PROMPT"
                mode_tmux         "#[bg=#151515,fg=#E1E1E1] TMUX"

                tab_normal              "#[bg=#151515,fg=#727272] {index}:{name} "
                tab_normal_fullscreen   "#[bg=#151515,fg=#727272] {index}:{name}[] "
                tab_normal_sync         "#[bg=#151515,fg=#727272] {index}:{name}<> "
                tab_active              "#[bg=#151515,fg=#FFFFFF,bold] {index}:{name} "
                tab_active_fullscreen   "#[bg=#151515,fg=#FFFFFF,bold] {index}:{name}[] "
                tab_active_sync         "#[bg=#151515,fg=#FFFFFF,bold] {index}:{name}<> "
            }
        }
    }

    tab focus=true {
        pane split_direction="vertical" {
            pane focus=true size="65%"
            pane size="35%"
        }
    }
}
